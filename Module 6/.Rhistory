for (t in 2:n) {
x = X[t - 1, ]
for (i in 1:p) {
x_mean_minus = (sum(x) - x[i]) / (p - 1)
x[i] = rnorm(1, mean = conditional_mean_coeff * x_mean_minus, sd = sigma)
}
X[t, ] = x
}
X
}
